# OneDrive Connector — Runtime Environment Variables
# Copy this file to .env and fill in your credentials. Never commit .env.

# Required: Ask DIANA API key — get from https://app.askdiana.ai/developer
ASKDIANA_API_KEY=askd_your_key_here

# Base URL for the Ask DIANA instance
ASKDIANA_BASE_URL=http://localhost:3007

# Skip SSL verification (Windows local dev only — do not use in production)
ASKDIANA_VERIFY_SSL=false

# Microsoft OAuth credentials — create at https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
ONEDRIVE_CLIENT_ID=your-azure-app-client-id
ONEDRIVE_CLIENT_SECRET=your-azure-app-client-secret
