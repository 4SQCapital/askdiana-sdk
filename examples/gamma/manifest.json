{
  "name": "Gamma",
  "slug": "gamma",
  "version": "1.0.0",
  "type": "ai_ml",
  "description": "Generate beautiful presentations, documents, and webpages powered by Gamma.app. Just describe what you need in chat and get a polished, shareable presentation with a live link and export options (PDF, PPTX, PNG).",
  "short_description": "AI presentations via Gamma.app",
  "permissions": [
    "chats:read",
    "chats:write",
    "ui:end_of_conversation"
  ],
  "webhooks": {
    "on_install": "http://localhost:5004/webhooks/install",
    "on_uninstall": "http://localhost:5004/webhooks/uninstall",
    "on_event": "http://localhost:5004/webhooks/events"
  },
  "capabilities": {},
  "trigger": {
    "intents": ["presentation", "report", "document", "summary", "slides", "deck"],
    "output_modes": ["STRUCTURED"],
    "description": "Create a presentation from this conversation"
  },
  "parameters": [
    {
      "name": "format",
      "type": "select",
      "label": "Format",
      "description": "Choose the output format for your Gamma creation.",
      "required": false,
      "options": [
        {"value": "presentation", "label": "Presentation"},
        {"value": "document", "label": "Document"},
        {"value": "webpage", "label": "Webpage"},
        {"value": "social", "label": "Social Post"}
      ],
      "default": "presentation"
    },
    {
      "name": "num_cards",
      "type": "select",
      "label": "Number of Slides",
      "description": "How many slides or cards to generate.",
      "required": false,
      "options": [
        {"value": "4", "label": "4"},
        {"value": "6", "label": "6"},
        {"value": "8", "label": "8"},
        {"value": "10", "label": "10"},
        {"value": "15", "label": "15"}
      ],
      "default": "8"
    },
    {
      "name": "export_format",
      "type": "select",
      "label": "Export Format",
      "description": "File format for the downloadable export.",
      "required": false,
      "options": [
        {"value": "pdf", "label": "PDF"},
        {"value": "pptx", "label": "PowerPoint"},
        {"value": "png", "label": "PNG"}
      ],
      "default": "pdf"
    },
    {
      "name": "template_mode",
      "type": "select",
      "label": "Template Mode",
      "description": "Use a Gamma template to style the output. Leave as 'No Template' for the default AI theme.",
      "required": false,
      "options": [
        {"value": "none", "label": "No Template"},
        {"value": "manual", "label": "Manual - enter a Template ID"},
        {"value": "auto_select", "label": "Auto - pick best match from your library"}
      ],
      "default": "none"
    },
    {
      "name": "content_amount",
      "type": "select",
      "label": "Content Density",
      "description": "Controls how much text is placed on each slide.",
      "required": false,
      "options": [
        {"value": "brief", "label": "Brief - short bullet points"},
        {"value": "medium", "label": "Medium - balanced"},
        {"value": "detailed", "label": "Detailed - rich paragraphs"}
      ],
      "default": "medium"
    },
    {
      "name": "template_id",
      "type": "select",
      "label": "Theme",
      "description": "Pick a theme from your Gamma workspace. Loaded from your account - requires API key in settings.",
      "required": false,
      "options": [],
      "source": "/api/themes",
      "placeholder": "Default theme",
      "advanced": true
    },
    {
      "name": "logo_url",
      "type": "text",
      "label": "Logo URL",
      "description": "A publicly accessible URL for your company logo. Added to the title slide when provided.",
      "required": false,
      "placeholder": "https://your-domain.com/logo.png",
      "advanced": true
    },
    {
      "name": "brand_name",
      "type": "text",
      "label": "Brand Name",
      "description": "Your company or brand name. Shown on the title slide alongside the logo.",
      "required": false,
      "placeholder": "e.g. Acme Corp",
      "advanced": true
    }
  ],
  "invocation": {
    "url": "/api/invoke",
    "result_type": "rich_response"
  },
  "pricing": {
    "model": "free"
  },
  "ui": {
    "type": "schema",
    "settings_form": {
      "fields": [
        {
          "name": "api_key",
          "type": "password",
          "label": "Gamma API Key",
          "required": false,
          "placeholder": "Enter your Gamma.app API key (from Account Settings > API Keys)"
        },
        {
          "name": "format",
          "type": "select",
          "label": "Default Format",
          "required": false,
          "options": [
            "presentation",
            "document",
            "webpage",
            "social"
          ],
          "default": "presentation"
        },
        {
          "name": "num_cards",
          "type": "select",
          "label": "Number of Slides",
          "required": false,
          "options": ["4", "6", "8", "10", "15"],
          "default": "8"
        },
        {
          "name": "export_format",
          "type": "select",
          "label": "Export Format",
          "required": false,
          "options": ["pdf", "pptx", "png"],
          "default": "pdf"
        },
        {
          "name": "tone",
          "type": "text",
          "label": "Content Tone",
          "required": false,
          "placeholder": "e.g. professional, creative, casual"
        },
        {
          "name": "language",
          "type": "select",
          "label": "Output Language",
          "required": false,
          "options": ["en", "ar", "fr", "es", "de", "zh", "ja", "ko"],
          "default": "en"
        },
        {
          "name": "template_mode",
          "type": "select",
          "label": "Template Mode",
          "required": false,
          "options": ["none", "manual", "auto_select"],
          "default": "none"
        },
        {
          "name": "template_id",
          "type": "text",
          "label": "Template ID",
          "required": false,
          "placeholder": "Gamma template ID for manual template selection"
        },
        {
          "name": "template_name",
          "type": "text",
          "label": "Template Name",
          "required": false,
          "placeholder": "Preferred name for auto-select from templates"
        },
        {
          "name": "model",
          "type": "text",
          "label": "Model",
          "required": false,
          "placeholder": "Optional Gamma model identifier"
        },
        {
          "name": "content_amount",
          "type": "select",
          "label": "Content Density",
          "required": false,
          "options": ["brief", "medium", "detailed"],
          "default": "medium"
        },
        {
          "name": "logo_url",
          "type": "text",
          "label": "Logo URL (optional)",
          "required": false,
          "placeholder": "Applied only when provided"
        },
        {
          "name": "brand_name",
          "type": "text",
          "label": "Brand Name (optional)",
          "required": false,
          "placeholder": "Applied only when provided"
        }
      ]
    }
  }
}
