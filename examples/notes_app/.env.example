# Notes App Extension — Runtime Environment Variables
# Copy this file to .env and fill in your credentials. Never commit .env.

# Required: Ask DIANA API key — get from https://app.askdiana.ai/developer
ASKDIANA_API_KEY=askd_your_key_here

# Base URL for the Ask DIANA instance (default: https://app.askdiana.ai)
ASKDIANA_BASE_URL=http://localhost:3007

# Install ID — provided when a user installs your extension (used for local testing)
ASKDIANA_INSTALL_ID=your-install-uuid-here

# Webhook signing secret (set to your ASKDIANA_API_KEY value)
WEBHOOK_SIGNING_SECRET=your-webhook-secret
