{
  "name": "Google Drive Connector",
  "slug": "google-drive-connector",
  "version": "1.0.0",
  "type": "connector",
  "description": "Connect Google Drive to import documents into Ask DIANA. Users install the extension and can browse folders, select files, and sync them into their knowledge base.",
  "short_description": "Import Google Drive documents into Ask DIANA",
  "permissions": [
    "documents:read",
    "documents:write",
    "user:profile"
  ],
  "webhooks": {
    "on_install": "https://<your-extension-url>/webhooks/install",
    "on_uninstall": "https://<your-extension-url>/webhooks/uninstall",
    "on_event": "https://<your-extension-url>/webhooks/events"
  },
  "capabilities": {
    "list_files": "https://<your-extension-url>/api/files",
    "sync": "https://<your-extension-url>/api/sync"
  },
  "pricing": {
    "model": "free"
  },
  "ui": {
    "type": "schema",
    "settings_form": {
      "fields": [
        {
          "name": "root_folder_id",
          "type": "text",
          "label": "Root Folder ID",
          "required": false,
          "placeholder": "Leave empty to list from root"
        },
        {
          "name": "auto_sync",
          "type": "checkbox",
          "label": "Auto-sync new files",
          "default": true
        }
      ]
    }
  }
}
