# Ask DIANA SDK credentials
ASKDIANA_API_KEY=askd_your_api_key_here
ASKDIANA_BASE_URL=https://app.askdiana.ai
WEBHOOK_SIGNING_SECRET=your-webhook-signing-secret

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Extension server
EXTENSION_BASE_URL=https://your-ngrok-url.ngrok.io
PORT=5004

# SQLite database path (optional, defaults to ./connector.db)
DATABASE_PATH=./connector.db
